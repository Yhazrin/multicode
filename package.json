{
  "name": "multicode",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @multicode/web dev",
    "build": "pnpm --filter @multicode/web build",
    "typecheck": "pnpm --filter @multicode/web typecheck",
    "test": "pnpm --filter @multicode/web test",
    "lint": "pnpm --filter @multicode/web lint",
    "clean": "pnpm --filter @multicode/web clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23"
  }
}
